            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Evidence and Interpretation"/>
                <para PARENT="Abden Heading 1"/>
                <ITEXT CH="The house style separates documented evidence from interpretation and unresolved questions."/>
                <para PARENT="Abden Body First"/>
                <ITEXT CH="Archival evidence"/>
                <para PARENT="Abden Heading 2"/>
                <ITEXT CH="Archive reference: National Records of Scotland, plans and correspondence relating to Abden."/>
                <para PARENT="Abden Archive Reference"/>
                <ITEXT CH="A block quotation is inset on both sides and set slightly smaller than the body text."/>
                <para PARENT="Abden Quote"/>
                <ITEXT CH="Reconstruction note: this feature is inferred from the combined map and photographic evidence."/>
                <para PARENT="Abden Reconstruction Note"/>
                <ITEXT CH="Established fact: the structure appears on the 1895 map. Probable interpretation: it served the adjacent workshop. Outstanding question: its exact construction date."/>
                <para PARENT="Abden Evidence Assessment"/>
