        <PAGEOBJECT XPOS="156.693913385827" YPOS="2750.71966141732" OwnPage="5" ItemID="2076216192" PTYPE="4" WIDTH="467.716535433071" HEIGHT="657.637795275591" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" ANNAME="Style_Specimen" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L467.717 0 L467.717 657.638 L0 657.638 L0 0 Z" copath="M0 0 L467.717 0 L467.717 657.638 L0 657.638 L0 0 Z" gXpos="156.693913385827" gYpos="2750.71966141732" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Evidence, Interpretation and Reconstruction"/>
                <para PARENT="Abden Heading 1"/>
                <ITEXT CH="Map evidence"/>
                <para PARENT="Abden Evidence Heading"/>
                <ITEXT CH="1895 Ordnance Survey 25-inch map, Fifeshire XL.8."/>
                <para PARENT="Abden Archive Reference"/>
                <ITEXT CH="Established fact: a masonry projection is visible. Interpretation: it probably represents the concrete and rubble pier recorded in 1964."/>
                <para PARENT="Abden Evidence Assessment"/>
                <ITEXT CH="Confidence: Moderate"/>
                <para PARENT="Abden Confidence Rating"/>
                <ITEXT CH="Orientation: approximately north-east to south-west. Dimensions: to be verified from georeferenced mapping."/>
                <para PARENT="Abden Technical Specification"/>
                <ITEXT CH="Blender note: model the pier as a separate object; retain editable length, width and deck-height parameters."/>
                <para PARENT="Abden Blender Note"/>
                <ITEXT CH="• Was the short breakwater integral with the pier or a later addition?"/>
                <para PARENT="Abden Outstanding Question"/>
                <ITEXT CH="See Figure 14.3 and Map 6.2."/>
                <para PARENT="Abden Figure Reference"/>
                <ITEXT CH="See Table A.12, Feature Register."/>
                <trail PARENT="Abden Table Reference"/>
            </StoryText>
        </PAGEOBJECT>
